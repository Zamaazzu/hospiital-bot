@"
# Python (backend)
__pycache__/
*.py[cod]
*`$py.class
*.so
.Python
venv/
env/
ENV/

# Database
*.db
*.sqlite3

# Node (frontend)
node_modules/
dist/
dist-ssr/
*.local

# Environment variables
.env
.env.local

# Models
models/*
!models/.gitkeep

# Data files
data/*.xlsx
data/*.csv
data/*.json
!data/.gitkeep

# Audio files
*.wav
*.mp3

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
"@ | Out-File -FilePath .gitignore -Encoding utf8